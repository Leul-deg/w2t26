# ============================================================
# LMS Frontend — Environment Configuration Example
# Copy this file to .env and fill in the values.
# All VITE_ prefixed variables are bundled into the client build.
# Do NOT put secrets or credentials in frontend env vars.
# ============================================================

# The base URL of the backend API, used in production builds.
# In development, Vite proxies /api/* to the backend automatically (see vite.config.ts).
# Only needed when running `npm run build` for a production deployment.
VITE_API_BASE_URL=http://localhost:8080
